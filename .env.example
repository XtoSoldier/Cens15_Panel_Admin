# =============================================================================
# EJEMPLO DE CONFIGURACIÓN - Copiar a .env.local y completar los valores
# =============================================================================

# Entorno: development | staging | production
REACT_APP_ENV=development

# URL base de la API
REACT_APP_API_BASE_URL=http://localhost:4000/api/v1

# Habilitar mock de API (solo en desarrollo)
REACT_APP_MOCK_API=true

# Habilitar debug
REACT_APP_DEBUG=true

# Nivel de logs (error, warn, info, debug)
REACT_APP_LOG_LEVEL=info

# Formato de fecha (DD/MM/YYYY, MM/DD/YYYY, YYYY-MM-DD)
REACT_APP_DATE_FORMAT=DD/MM/YYYY

# Idioma default (es, en, pt)
REACT_APP_DEFAULT_LANGUAGE=es

# Timeout de requests en ms
REACT_APP_REQUEST_TIMEOUT=30000
