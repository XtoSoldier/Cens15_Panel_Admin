# =============================================================================
# CONFIGURACIÓN BASE - Valores compartidos por todos los entornos
# =============================================================================

# Nivel de logs de la aplicación (error, warn, info, debug)
REACT_APP_LOG_LEVEL=info

# Formato de fecha default (DD/MM/YYYY, MM/DD/YYYY, YYYY-MM-DD)
REACT_APP_DATE_FORMAT=DD/MM/YYYY

# Idioma default (es, en, pt)
REACT_APP_DEFAULT_LANGUAGE=es

# Timeout de requests en ms
REACT_APP_REQUEST_TIMEOUT=30000
